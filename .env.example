# Database Configuration
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=lauti_market
DB_SSLMODE=disable

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production

# Server Configuration
PORT=:8000

# Image Service (gRPC)
IMAGE_STORE_ADDR=localhost:50051

# Unsplash API (for download-images script)
UNSPLASH_ACCESS_KEY=your-unsplash-api-key

# Mercado Pago (Checkout Pro)
# Get Test Credentials from: https://www.mercadopago.com.ar/developers/panel/app/7745378443257131/test-credentials
# Test Access Token format: TEST-xxxxxxxx-031621-xxxx-xxxxxxxx-xxxxxxxx
MERCADO_PAGO_ACCESS_TOKEN=your-mercado-pago-access-token
MERCADO_PAGO_WEBHOOK_SECRET=your-mercado-pago-webhook-secret
# Frontend URL used in preference back_urls (e.g., http://localhost:3000 for local dev)
FRONTEND_BASE_URL=http://localhost:3000
# Public webhook URL (requires ngrok or similar for local testing; leave empty to skip)
MERCADO_PAGO_NOTIFICATION_URL=

# Logging Configuration
# Set to 'debug' for verbose logging in development, 'info' for production
LOG_LEVEL=debug
