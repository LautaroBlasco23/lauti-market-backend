{
  "info": {
    "name": "Lauti Market API - Stores",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "storeId", "value": "" }
  ],
  "item": [
    {
      "name": "7. Create Store",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "    const response = pm.response.json();",
              "    pm.collectionVariables.set('storeId', response.id);",
              "    pm.test('Store created successfully', function() {",
              "        pm.expect(response.id).to.exist;",
              "        pm.expect(response.name).to.equal('Tech Store');",
              "        pm.expect(response.description).to.exist;",
              "        pm.expect(response.address).to.exist;",
              "        pm.expect(response.phone_number).to.exist;",
              "    });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Tech Store\",\n    \"description\": \"Your one-stop shop for tech gadgets\",\n    \"address\": \"123 Main St, City, Country\",\n    \"phone_number\": \"+1234567890\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/stores",
          "host": ["{{baseUrl}}"],
          "path": ["stores"]
        }
      }
    },
    {
      "name": "8. Get All Stores",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const response = pm.response.json();",
              "    pm.test('Stores retrieved successfully', function() {",
              "        pm.expect(response).to.be.an('array');",
              "        if (response.length > 0) {",
              "            pm.expect(response[0].id).to.exist;",
              "            pm.expect(response[0].name).to.exist;",
              "        }",
              "    });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{baseUrl}}/stores",
          "host": ["{{baseUrl}}"],
          "path": ["stores"]
        }
      }
    },
    {
      "name": "9. Get Store by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const response = pm.response.json();",
              "    pm.test('Store retrieved successfully', function() {",
              "        pm.expect(response.id).to.exist;",
              "        pm.expect(response.name).to.exist;",
              "        pm.expect(response.description).to.exist;",
              "        pm.expect(response.address).to.exist;",
              "        pm.expect(response.phone_number).to.exist;",
              "    });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{baseUrl}}/stores/{{storeId}}",
          "host": ["{{baseUrl}}"],
          "path": ["stores", "{{storeId}}"]
        }
      }
    },
    {
      "name": "10. Update Store",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const response = pm.response.json();",
              "    pm.test('Store updated successfully', function() {",
              "        pm.expect(response.name).to.equal('Updated Tech Store');",
              "        pm.expect(response.description).to.equal('Updated description');",
              "    });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Updated Tech Store\",\n    \"description\": \"Updated description\",\n    \"address\": \"456 New St, City, Country\",\n    \"phone_number\": \"+0987654321\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/stores/{{storeId}}",
          "host": ["{{baseUrl}}"],
          "path": ["stores", "{{storeId}}"]
        }
      }
    },
    {
      "name": "11. Delete Store",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Store deleted successfully', function() {",
              "    pm.expect(pm.response.code).to.equal(204);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{baseUrl}}/stores/{{storeId}}",
          "host": ["{{baseUrl}}"],
          "path": ["stores", "{{storeId}}"]
        }
      }
    }
  ]
}
