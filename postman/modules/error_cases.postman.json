{
  "info": {
    "name": "Lauti Market API - Error Cases",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "storeId", "value": "" }
  ],
  "item": [
    {
      "name": "Register User - Invalid Email",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"invalid-email\",\n    \"password\": \"password123\",\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register/user",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register", "user"]
        }
      }
    },
    {
      "name": "Register User - Short Password",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"test2@example.com\",\n    \"password\": \"short\",\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register/user",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register", "user"]
        }
      }
    },
    {
      "name": "Register Store - Missing Fields",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"store2@example.com\",\n    \"password\": \"password123\",\n    \"name\": \"Store Name\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register/store",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register", "store"]
        }
      }
    },
    {
      "name": "Login - Wrong Password",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"wrongpassword\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "Get User - Not Found",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{baseUrl}}/users/non-existent-id",
          "host": ["{{baseUrl}}"],
          "path": ["users", "non-existent-id"]
        }
      }
    },
    {
      "name": "Get Store - Not Found",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{baseUrl}}/stores/non-existent-id",
          "host": ["{{baseUrl}}"],
          "path": ["stores", "non-existent-id"]
        }
      }
    },
    {
      "name": "Update Store - Invalid Data",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"\",\n    \"description\": \"Invalid update\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/stores/{{storeId}}",
          "host": ["{{baseUrl}}"],
          "path": ["stores", "{{storeId}}"]
        }
      }
    },
    {
      "name": "Create Product - Invalid Store",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Test Product\",\n    \"description\": \"Test description for the product\",\n    \"stock\": 10,\n    \"price\": 19.99\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/stores/non-existent-id/products",
          "host": ["{{baseUrl}}"],
          "path": ["stores", "non-existent-id", "products"]
        }
      }
    },
    {
      "name": "Create Product - Negative Stock",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Test Product\",\n    \"description\": \"Test description for the product\",\n    \"stock\": -5,\n    \"price\": 19.99\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/stores/{{storeId}}/products",
          "host": ["{{baseUrl}}"],
          "path": ["stores", "{{storeId}}", "products"]
        }
      }
    },
    {
      "name": "Create Product - Zero Price",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Test Product\",\n    \"description\": \"Test description for the product\",\n    \"stock\": 10,\n    \"price\": 0\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/stores/{{storeId}}/products",
          "host": ["{{baseUrl}}"],
          "path": ["stores", "{{storeId}}", "products"]
        }
      }
    },
    {
      "name": "Get Product - Not Found",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{baseUrl}}/stores/{{storeId}}/products/non-existent-id",
          "host": ["{{baseUrl}}"],
          "path": ["stores", "{{storeId}}", "products", "non-existent-id"]
        }
      }
    }
  ]
}
